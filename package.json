{
  "name": "vecinita-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "dev": "vite",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src e2e vite.config.ts vitest.config.ts playwright.config.ts --ext .ts,.tsx",
    "lint:fix": "eslint src e2e vite.config.ts vitest.config.ts playwright.config.ts --ext .ts,.tsx --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.{ts,tsx}\" index.html components.json vite.config.ts vitest.config.ts playwright.config.ts postcss.config.mjs",
    "format:write": "prettier --write \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.{ts,tsx}\" index.html components.json vite.config.ts vitest.config.ts playwright.config.ts postcss.config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.playwright.json"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
