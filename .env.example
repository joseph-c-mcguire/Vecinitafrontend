# Vecinita Frontend Environment Variables

# Backend Gateway URL (unified API)
# Development: keep /api so Vite proxy handles backend routing and CORS
# Production: set to your deployed gateway URL (e.g. https://your-gateway/api/v1)
VITE_GATEWAY_URL=/api

# Optional: Vite dev proxy target (used by vite.config.ts)
# Set this if your gateway runs on a different host/port
VITE_GATEWAY_PROXY_TARGET=http://127.0.0.1:8004

# Agent request timeouts
# Keep the non-stream timeout above the gateway AGENT_TIMEOUT so the UI receives
# backend fallback responses instead of aborting first.
VITE_AGENT_REQUEST_TIMEOUT_MS=90000
VITE_AGENT_STREAM_TIMEOUT_MS=120000
VITE_AGENT_STREAM_FIRST_EVENT_TIMEOUT_MS=15000

# Supabase Configuration
# Get these from https://app.supabase.com/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Local dev admin login fallback (used when Supabase env vars are missing)
VITE_DEV_ADMIN_ENABLED=true
VITE_DEV_ADMIN_EMAIL=admin@vecinita.local
VITE_DEV_ADMIN_PASSWORD=VecinitaAdmin!2026
VITE_DEV_ADMIN_TOKEN=vecinita-dev-admin-token-2026
